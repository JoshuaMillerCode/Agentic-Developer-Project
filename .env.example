# =============================================================================
# API Keys (required for runtime — never commit .env or real values)
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# =============================================================================

# TMDB (The Movie Database) API — used by the MCP Server
# Get your key: https://www.themoviedb.org/settings/api
# Auth: pass as ?api_key=... query param, or as Authorization: Bearer <token>
TMDB_API_KEY=

# LLM — used by the Agent Backend (Phase 3). Primary: Anthropic. Alternative: OpenAI.
# Anthropic (primary): https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI (alternative): https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Backend (optional overrides)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# CORS_ALLOW_CREDENTIALS=true
# ANTHROPIC_MODEL=claude-sonnet-4-6
#   Other valid IDs: claude-sonnet-4-5, claude-opus-4-6, claude-haiku-4-5. See backend/app.py or
#   https://docs.anthropic.com/en/docs/about-claude/models
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_TOKENS=4096
# MCP_SERVER_SCRIPT=   (path to mcp-server/server.py if not using default)
# MAX_MESSAGE_LENGTH=32000
# HOST=0.0.0.0
# PORT=8000
# RELOAD=true   (set false for production)
