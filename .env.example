# =============================================================================
# API Keys (required for runtime — never commit .env or real values)
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# =============================================================================

# TMDB (The Movie Database) API — used by the MCP Server
# Get your key: https://www.themoviedb.org/settings/api
# Auth: pass as ?api_key=... query param, or as Authorization: Bearer <token>
TMDB_API_KEY=
